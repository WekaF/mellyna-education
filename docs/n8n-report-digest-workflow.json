{
  "name": "Mellyna - Report Digest Cron",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Daily 07:00 WIB",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [220, 240],
      "notes": "Runs daily at 07:00 WIB (UTC+7 = 00:00 UTC). Adjust timezone in N8N settings."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:3000/api/cron/report-digest?type=daily&secret=change-this-to-random-secret",
        "options": {}
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "Send Daily Admin Digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 240]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "weeksInterval": 1,
              "triggerAtDay": [1],
              "triggerAtHour": 1,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
      "name": "Weekly Monday 08:00 WIB",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [220, 480],
      "notes": "Runs every Monday at 08:00 WIB (UTC+7 = 01:00 UTC). Adjust timezone in N8N settings."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:3000/api/cron/report-digest?type=weekly&secret=change-this-to-random-secret",
        "options": {}
      },
      "id": "d4e5f6a7-b8c9-0123-defa-234567890123",
      "name": "Send Weekly Parent Digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 480]
    }
  ],
  "connections": {
    "Daily 07:00 WIB": {
      "main": [
        [
          {
            "node": "Send Daily Admin Digest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Weekly Monday 08:00 WIB": {
      "main": [
        [
          {
            "node": "Send Weekly Parent Digest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}
