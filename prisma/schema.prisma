generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(cuid())
  name                   String
  email                  String             @unique
  emailVerified          DateTime?
  password               String?
  phone                  String?
  role                   Role               @default(PARENT)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  suspended              Boolean            @default(false)
  accounts               Account[]
  tutorClasses           Class[]            @relation("TutorClasses")
  additionalTutorClasses ClassTutor[]       @relation("AdditionalTutorClasses")
  reports                LearningReport[]
  sessions               Session[]
  children               Student[]          @relation("ParentStudents")
  milestoneUpdates       StudentMilestone[] @relation("MilestoneUpdater")
  milestoneReports     MilestoneReport[] @relation("MilestoneReportGenerator")
  passwordResetTokens  PasswordResetToken[]
}

model Student {
  id                   String                @id @default(cuid())
  name                 String
  birthDate            DateTime?
  grade                String?
  notes                String?
  parentId             String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  isActive             Boolean               @default(true)
  attendances          Attendance[]
  enrollments          Enrollment[]
  invoices             Invoice[]
  reports              LearningReport[]
  scheduleParticipants ScheduleParticipant[]
  parent               User                  @relation("ParentStudents", fields: [parentId], references: [id])
  studentMilestones    StudentMilestone[]
  milestoneReports     MilestoneReport[]
  programEnrollments   ProgramEnrollment[]
}

model Class {
  id               String         @id @default(cuid())
  name             String
  description      String?
  tutorId          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  dayOfWeek        DayOfWeek?
  timeSlot         String?
  mainProgram      Program?
  tutor            User           @relation("TutorClasses", fields: [tutorId], references: [id])
  programs         ClassProgram[]
  additionalTutors ClassTutor[]   @relation("AdditionalTutors")
  enrollments      Enrollment[]
  schedules        Schedule[]
}

model ClassProgram {
  id      String  @id @default(cuid())
  classId String
  program Program
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, program])
}

model Enrollment {
  id                  String             @id @default(cuid())
  studentId           String
  classId             String
  programEnrollmentId String?
  joinedAt            DateTime           @default(now())
  class               Class              @relation(fields: [classId], references: [id])
  student             Student            @relation(fields: [studentId], references: [id])
  programEnrollment   ProgramEnrollment? @relation(fields: [programEnrollmentId], references: [id], onDelete: SetNull)

  @@unique([studentId, classId])
}

model ProgramEnrollment {
  id          String                  @id @default(cuid())
  studentId   String
  program     Program
  status      ProgramEnrollmentStatus @default(ACTIVE)
  startedAt   DateTime                @default(now())
  endedAt     DateTime?
  notes       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@index([studentId, status])
}

model ClassTutor {
  id        String   @id @default(cuid())
  classId   String
  tutorId   String
  createdAt DateTime @default(now())
  class     Class    @relation("AdditionalTutors", fields: [classId], references: [id], onDelete: Cascade)
  tutor     User     @relation("AdditionalTutorClasses", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([classId, tutorId])
}

model Schedule {
  id                String                @id @default(cuid())
  classId           String
  date              DateTime
  startTime         String
  endTime           String
  topic             String?
  location          String?
  status            ScheduleStatus        @default(DRAFT)
  publishedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  isRecurring       Boolean               @default(false)
  recurrenceGroupId String?
  recurrenceWeeks   Int?
  attendances       Attendance[]
  reports           LearningReport[]
  class             Class                 @relation(fields: [classId], references: [id])
  participants      ScheduleParticipant[]

  @@index([recurrenceGroupId])
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  scheduleId String
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  markedAt   DateTime         @default(now())
  schedule   Schedule         @relation(fields: [scheduleId], references: [id])
  student    Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, scheduleId])
}

model ScheduleParticipant {
  id         String   @id @default(cuid())
  scheduleId String
  studentId  String
  createdAt  DateTime @default(now())
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, studentId])
}

model LearningReport {
  id               String    @id @default(cuid())
  studentId        String
  scheduleId       String
  tutorId          String
  content          String
  score            Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  parentNotifiedAt DateTime?
  schedule         Schedule  @relation(fields: [scheduleId], references: [id])
  student          Student   @relation(fields: [studentId], references: [id])
  tutor            User      @relation(fields: [tutorId], references: [id])
  media            Media[]

  @@unique([studentId, scheduleId])
}

model Media {
  id        String         @id @default(cuid())
  reportId  String
  url       String
  type      MediaType
  filename  String
  size      Int
  createdAt DateTime       @default(now())
  report    LearningReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id          String        @id @default(cuid())
  studentId   String
  amount      Int
  description String
  dueDate     DateTime
  status      InvoiceStatus @default(PENDING)
  midtransId  String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  student     Student       @relation(fields: [studentId], references: [id])
  payments    Payment[]
}

model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  amount       Int
  method       String?
  status       PaymentStatus @default(PENDING)
  snapToken    String?
  snapUrl      String?
  midtransData Json?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyPiket {
  day       String   @id
  staff     String
  updatedAt DateTime @updatedAt
}

model Milestone {
  id                String             @id @default(cuid())
  name              String
  description       String?
  program           Program
  order             Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  studentMilestones StudentMilestone[]

  @@index([program, order])
}

model StudentMilestone {
  id          String          @id @default(cuid())
  studentId   String
  milestoneId String
  status      MilestoneStatus @default(NOT_STARTED)
  completedAt DateTime?
  notes       String?
  updatedById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  milestone   Milestone       @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  updatedBy   User?           @relation("MilestoneUpdater", fields: [updatedById], references: [id])

  @@unique([studentId, milestoneId])
}

model MilestoneReport {
  id             String           @id @default(cuid())
  studentId      String
  periodType     ReportPeriodType
  periodLabel    String
  periodStart    DateTime
  periodEnd      DateTime
  notes          String?          @db.Text
  snapshotJson   Json
  sessionSummary Json
  generatedById  String
  notifiedAt     DateTime?
  createdAt      DateTime         @default(now())

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  generatedBy User    @relation("MilestoneReportGenerator", fields: [generatedById], references: [id])

  @@index([studentId, createdAt])
}

enum Role {
  SUPER_ADMIN
  TUTOR
  PARENT
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  SICK
  PERMISSION
}

enum MediaType {
  PHOTO
  VIDEO
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Program {
  SEMPOA
  AHE
  EFK
  EYL
  EFE
  CALISTUNG
  ENGLISH
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ReportPeriodType {
  MONTHLY
  SEMESTER
  CUSTOM
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ProgramEnrollmentStatus {
  ACTIVE
  COMPLETED
  UPGRADED
  DROPPED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
